// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  plan          Plan      @default(FREE)
  trialEndsAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  linkedInAccs  LinkedInAccount[]
  campaigns     Campaign[]
  contacts      Contact[]
  conversations Conversation[]
  settings      UserSettings?
  messages      Message[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model LinkedInAccount {
  id          String   @id @default(cuid())
  userId      String
  name        String
  profileUrl  String?
  avatar      String?
  status      LinkedInStatus @default(ACTIVE)
  dailyLimit  Int      @default(25)
  sentToday   Int      @default(0)
  proxy       String?
  cookie      String?  // LinkedIn session cookie
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  messages      Message[]

  @@map("linkedin_accounts")
}

model Contact {
  id              String   @id @default(cuid())
  userId          String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  linkedInUrl     String?
  company         String?
  position        String?
  location        String?
  avatar          String?
  enriched        Boolean  @default(false)
  enrichedData    Json?    // Data from Prospeo, Dropcontact, etc.
  tags            String[]
  notes           String?
  status          ContactStatus @default(NEW)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignContacts CampaignContact[]
  conversations   Conversation[]

  @@map("contacts")
}

model Campaign {
  id            String         @id @default(cuid())
  userId        String
  name          String
  status        CampaignStatus @default(DRAFT)
  dailyLimit    Int            @default(25)
  totalContacts Int            @default(0)
  sentCount     Int            @default(0)
  replyCount    Int            @default(0)
  meetingCount  Int            @default(0)
  settings      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps    CampaignStep[]
  contacts CampaignContact[]
  conversations Conversation[] 

  @@map("campaigns")
}

model CampaignStep {
  id          String    @id @default(cuid())
  campaignId  String

  order       Int
  type        StepType

  delay       Int       @default(0) // hours

  subject     String?
  content     String?

  aiEnhanced  Boolean   @default(false)

  createdAt   DateTime  @default(now())

  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  executions  CampaignStepExecution[]

  @@map("campaign_steps")
}

model CampaignContact {
  id            String                  @id @default(cuid())

  campaignId    String
  contactId     String

  status        CampaignContactStatus   @default(PENDING)

  currentStep   Int                     @default(0)

  nextSendAt    DateTime?

  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  campaign      Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  contact       Contact                 @relation(fields: [contactId], references: [id], onDelete: Cascade)

  executions    CampaignStepExecution[]

  @@unique([campaignId, contactId])

  @@map("campaign_contacts")
}

model CampaignStepExecution {
  id                 String    @id @default(cuid())

  campaignContactId  String?
  stepId             String?

  status             ExecutionStatus @default(PENDING)

  scheduledFor       DateTime?

  executedAt         DateTime?

  error              String?

  createdAt          DateTime  @default(now())

  updatedAt DateTime @updatedAt

  campaignContact    CampaignContact? @relation(fields: [campaignContactId], references: [id], onDelete: Cascade)

  step               CampaignStep? @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("campaign_step_executions")
}

model Conversation {
  id              String   @id @default(cuid())
  userId          String
  contactId       String
  linkedInAccId   String?
   campaignId    String? 
  channel         Channel  @default(LINKEDIN)
  lastMessageAt   DateTime @default(now())
  unreadCount     Int      @default(0)
  status          ConvStatus @default(ACTIVE)
  createdAt       DateTime @default(now())

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact     Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  linkedInAcc LinkedInAccount? @relation(fields: [linkedInAccId], references: [id])
   campaign    Campaign?        @relation(fields: [campaignId], references: [id])  
  messages    Message[]

  @@map("conversations")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  userId         String
  linkedInAccId  String?
  direction      Direction
  type           MessageType @default(TEXT)
  content        String
  sentAt         DateTime    @default(now())
  replyAt        DateTime?
  readAt         DateTime?
  aiGenerated    Boolean     @default(false)

  conversation Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedInAcc  LinkedInAccount? @relation(fields: [linkedInAccId], references: [id])

  @@map("messages")
}

enum Plan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum LinkedInStatus {
  ACTIVE
  PAUSED
  BLOCKED
  WARMING
}

enum ContactStatus {
  NEW
  CONTACTED
  REPLIED
  INTERESTED
  NOT_INTERESTED
  CONVERTED
}

enum CampaignStatus {
  DRAFT
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
}

enum CampaignContactStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
}

enum StepType {
  CONNECTION_REQUEST
  MESSAGE
  EMAIL
  VOICE_NOTE
  WHATSAPP
  FOLLOW_UP
  WAIT
}

enum Channel {
  LINKEDIN
  EMAIL
  WHATSAPP
  PHONE
}

enum ConvStatus {
  ACTIVE
  ARCHIVED
  SPAM
}

enum Direction {
  SENT
  RECEIVED
}

enum MessageType {
  TEXT
  VOICE
  IMAGE
  FILE
}

enum ExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])

  @@map("verification_tokens")
}

model UserSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  workspaceName String?
  timezone      String   @default("Asia/Kolkata")
  language      String   @default("English")
  avatar        String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}